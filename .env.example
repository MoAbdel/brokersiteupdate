# Environment Variables Template

# Database Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Notifications (Resend.com - Sign up for free at https://resend.com)
RESEND_API_KEY=your_resend_api_key

# SMS Notifications (Optional - Twilio - Sign up at https://www.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number
YOUR_PHONE_NUMBER=+19495792057   # Your personal phone to receive SMS

# Webhook Notifications (Optional - for Zapier, Make, n8n, etc.)
WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=your_facebook_pixel_id

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin Dashboard Password (for /admin access)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# SEO Submission Automation
# Disabled by default. Production alone must never submit URLs.
BING_API_KEY=
BING_WEBMASTER_API_KEY=  # Optional alias for older scripts
BING_SITE_URL=https://www.mothebroker.com
BING_URL_DAILY_QUOTA=100
GSC_SITE_URL=sc-domain:mothebroker.com
GSC_SITEMAP_URL=https://www.mothebroker.com/sitemap.xml
GSC_INDEXING_DAILY_QUOTA=200
INDEXNOW_KEY=
INDEXNOW_HOST=www.mothebroker.com
DISABLE_AUTO_INDEXING_ON_PROD=true
DISABLE_INDEXING_SUBMISSIONS=true
ENABLE_INDEXING_SUBMISSIONS=false
INDEXING_SUBMISSION_MODE=
INDEXING_APPROVED_DEPLOY_SHA=
INDEXING_URL_ALLOWLIST_FILE=reports/indexing-allowlist-2026-06-05.json
INDEXING_VALIDATE_LIVE=false
ENABLE_GSC_SITEMAP_SUBMIT=false
SEO_RETRY_ATTEMPTS=3
SEO_RETRY_BASE_DELAY_MS=1000
SEO_RESUBMIT_WINDOW_HOURS=48
